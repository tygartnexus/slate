# Optional provider configuration. Leave unset for local-only Gemma/Ollama.
OLLAMA_URL=http://localhost:11434
GEMMA_MODEL=gemma4:latest
GEMMA_NUM_PREDICT=700

# Cloud provider lanes use your own provider accounts.
NVIDIA_API_KEY=replace-with-nvidia-api-key
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
